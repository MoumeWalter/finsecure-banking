# =============================================================
# FinSecure Banking — Template d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS committer le .env
# =============================================================

# --- Oracle XE ---
ORACLE_HOST=oracle-db
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1
ORACLE_USER=finsecure_admin
ORACLE_PASSWORD=change_me_strong_password
ORACLE_SYS_PASSWORD=change_me_sys_password

# --- MongoDB ---
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=finsecure_admin
MONGO_INITDB_ROOT_PASSWORD=change_me_strong_password
MONGO_DATABASE=finsecure

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=4G
SPARK_DRIVER_MEMORY=2G

# --- Hive ---
HIVE_METASTORE_URI=thrift://hive-metastore:9083

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_me_to_a_random_string_64_chars_minimum
API_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_ALGORITHM=HS256

# --- Airflow (Sprint 2) ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-db/airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me

# --- Kafka (Sprint 2) ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRANSACTIONS=transactions_stream

# --- Logs ---
LOG_LEVEL=INFO

# --- Environnement ---
ENVIRONMENT=development
